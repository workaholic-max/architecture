{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": ["src/*"],

            "@router": ["src/router/index.js"],
            "@router/*": ["src/router/*"],
            "@api": ["src/api/index.js"],
            "@domains/*": ["src/domains/*"],
            "@features/*": ["src/features/*"],
            "@shared/*": ["src/shared/*"],

            "@scss-vars": ["src/assets/styles/abstracts/variables/_index.scss"],
            "@scss-mixins": ["src/assets/styles/abstracts/mixins/_index.scss"],
            "@scss-functions": ["src/assets/styles/abstracts/functions/_index.scss"]
        }
    },
    "include": ["src", "dts"]
}